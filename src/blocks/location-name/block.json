{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "geotagr/location-name",
	"version": "0.6.0",
	"title": "Location Name",
	"category": "text",
	"description": "Display the location name attached to a post.",
	"keywords": [ "location", "place", "geo" ],
	"textdomain": "geotagr",
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"anchor": true,
		"color": {
			"background": true,
			"gradients": true,
			"link": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"fontFamily": true,
			"fontStyle": true,
			"fontWeight": true,
			"textDecoration": true,
			"textTransform": true,
			"letterSpacing": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	}
}
