<?xml version="1.0"?>
<phpunit
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.6/phpunit.xsd"
	bootstrap="tests/phpunit/bootstrap.php"
	colors="true"
	beStrictAboutTestsThatDoNotTestAnything="true">
	<testsuites>
		<testsuite name="unit">
			<file>./tests/phpunit/unit/Test_Meta.php</file>
			<file>./tests/phpunit/unit/Test_Metabox.php</file>
			<file>./tests/phpunit/unit/Test_Location_Taxonomy.php</file>
			<file>./tests/phpunit/unit/Test_Settings.php</file>
		</testsuite>
		<testsuite name="integration">
			<directory suffix=".php">./tests/phpunit</directory>
			<exclude>./tests/phpunit/unit</exclude>
			<exclude>./tests/phpunit/bootstrap.php</exclude>
		</testsuite>
	</testsuites>
	<coverage>
		<include>
			<directory suffix=".php">./includes</directory>
		</include>
	</coverage>
</phpunit>
